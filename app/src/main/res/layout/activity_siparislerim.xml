<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F9F9">

    <ImageView
        android:id="@+id/btnSiparisKapat"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_margin="16dp"
        android:padding="5dp"
        app:tint="#757575"/>

    <TextView
        android:id="@+id/txtBaslik"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Siparişlerim"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#333"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerSiparislerim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/txtBaslik"
        android:padding="10dp"
        android:clipToPadding="false"
        android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/layoutSiparisBos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_centerInParent="true"
        android:padding="30dp"
        android:visibility="visible">

        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/bottom_sheet_bg">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_shopping_cart"
                android:layout_gravity="center"
                app:tint="#4CAF50"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Henüz siparişiniz yok"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginTop="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verdiğiniz siparişlerin durumunu ve geçmiş siparişlerinizi buradan takip edebilirsiniz."
            android:textSize="14sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginTop="10dp"/>
    </LinearLayout>

</RelativeLayout>