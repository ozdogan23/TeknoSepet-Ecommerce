<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="30dp"
    android:gravity="center_horizontal"
    android:background="#0D1B2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:layout_marginBottom="20dp">

        <ImageView
            android:id="@+id/btnKapatX"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_close"
            app:tint="#8899A6"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@android:drawable/ic_lock_idle_lock"
        app:tint="#2F80ED"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Şifre Değiştir"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="40dp"/>

    <EditText
        android:id="@+id/inputEski"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Mevcut Şifreniz"
        android:inputType="textPassword"
        android:textColor="#FFFFFF"
        android:textColorHint="#50657D"
        android:background="@drawable/input_dark_bg"
        android:padding="15dp"
        android:layout_marginBottom="20dp"/>

    <EditText
        android:id="@+id/inputYeni"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Yeni Şifre"
        android:inputType="textPassword"
        android:textColor="#FFFFFF"
        android:textColorHint="#50657D"
        android:background="@drawable/input_dark_bg"
        android:padding="15dp"
        android:layout_marginBottom="20dp"/>

    <EditText
        android:id="@+id/inputTekrar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Yeni Şifre (Tekrar)"
        android:inputType="textPassword"
        android:textColor="#FFFFFF"
        android:textColorHint="#50657D"
        android:background="@drawable/input_dark_bg"
        android:padding="15dp"
        android:layout_marginBottom="40dp"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnKaydetOnayla"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Şifreyi Güncelle"
        android:background="@drawable/btn_blue_bg"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textAllCaps="false"/>

</LinearLayout>