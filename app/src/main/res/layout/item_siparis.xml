<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardCornerRadius="15dp"
    app:cardElevation="5dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="15dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/imgSiparisResim"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/bilgisayar"
                android:scaleType="centerCrop"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/txtSiparisUrunAdi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ürün Adı Listesi"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#000"/>

                <TextView
                    android:id="@+id/txtSiparisTarih"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="21.12.2025"
                    android:textSize="12sp"
                    android:textColor="#777"/>
            </LinearLayout>

            <TextView
                android:id="@+id/txtSiparisFiyat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 ₺"
                android:textStyle="bold"
                android:textColor="#4CAF50"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEE"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtSiparisDurum"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hazırlanıyor"
                android:textColor="#FF9800"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnSiparisIptal"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Siparişi İptal Et"
                android:textSize="12sp"
                android:backgroundTint="#D32F2F"
                android:textColor="#FFF"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>