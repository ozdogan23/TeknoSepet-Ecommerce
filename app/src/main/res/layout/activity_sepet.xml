<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F9F9">

    <ImageView
        android:id="@+id/btnSepetKapat"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_margin="16dp"
        android:padding="5dp"
        android:elevation="10dp"
        app:tint="#757575"/>

    <LinearLayout
        android:id="@+id/layoutSepetBos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_centerInParent="true"
        android:padding="30dp"
        android:visibility="visible"> <FrameLayout
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/bottom_sheet_bg">

        <ImageView
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:src="@drawable/ic_shopping_cart"
            android:layout_gravity="center"
            app:tint="#4CAF50"/>
    </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sepetinizde ürün yok"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginTop="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sepetinizde ürün bulunmamaktadır. Alışverişe başlamak için butona tıklayın."
            android:textSize="15sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="35dp"/>

        <Button
            android:id="@+id/btnAlisveriseBasla"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Alışverişe Başla"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:textAllCaps="false"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutSepetDolu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingTop="60dp"> <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewSepet"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="20dp"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="15dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Toplam Tutar:"
                    android:textSize="18sp"
                    android:textColor="#555555"/>

                <TextView
                    android:id="@+id/txtToplamTutar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 ₺"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#333333"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnSiparisOnayla"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Siparişi Onayla"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF50"
                android:textAllCaps="false"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>